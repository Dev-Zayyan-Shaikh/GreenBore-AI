# Set the default behavior to normalize all text files to LF on checkin
* text=auto eol=lf

# Force specific text file types to be LF
*.sh text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.html text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Explicitly declare binary files that must not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
