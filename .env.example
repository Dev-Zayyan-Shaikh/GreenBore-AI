# Application Metadata
PROJECT_NAME="GreenBore AI"
ENV=development
API_V1_STR="/api/v1"

# Security & CORS
# JSON array of origins allowed to connect
BACKEND_CORS_ORIGINS='["http://localhost", "http://localhost:5173", "http://localhost:80", "http://127.0.0.1:5173", "http://127.0.0.1:80"]'

# Database Configuration (Docker defaults)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=greenbore
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/greenbore

# LLM Configurations
GEMINI_API_KEY=""
